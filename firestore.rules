
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Get the user's profile data from Firestore
    function getUserProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Check if the user has a specific role (e.g., 'Admin', 'Governor')
    function hasRole(role) {
      return isSignedIn() && getUserProfile(request.auth.uid).roleId == role;
    }
    
    // Check if the user is an Admin
    function isAdmin() {
      return hasRole('Admin');
    }
    
    // Check if user is an officer of a specific club (President or Secretary)
    function isClubOfficer(clubId) {
        let club = get(/databases/$(database)/documents/clubs/$(clubId)).data;
        return isSignedIn() && (request.auth.uid == club.presidentId || request.auth.uid == club.secretaryId);
    }
    
    // Check if the user is the governor of a specific region
    function isRegionGovernor(regionId) {
        let region = get(/databases/$(database)/documents/regions/$(regionId)).data;
        return isSignedIn() && request.auth.uid == region.governorId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /users/{userId} {
      // A user can read their own profile.
      // An Admin can read any profile.
      // A club officer can read profiles of members in their own club.
      // A regional governor can read profiles of members in their own region.
      // Allow public reads for development
      allow read: if true;
                  
      // A user can update their own profile (limited fields). Admins can update any profile.
      allow update: if (isOwner(userId) && request.resource.data.keys().hasOnly(['firstName', 'lastName', 'contactInfo', 'avatarUrl', 'idPhotoUrl'])) ||
                     isAdmin();
                     
      // Only Admins can create or delete users.
      allow create, delete: if isAdmin();
    }
    
    match /regions/{regionId} {
      // All signed-in users can read region data.
      allow read: if isSignedIn();
      // Only Admins can create, update, or delete regions.
      allow write: if isAdmin();
    }
    
    match /clubs/{clubId} {
       // Members of the region can read club data.
       // Admins can read any club.
      allow read: if isSignedIn() && (
                    getUserProfile(request.auth.uid).regionId == resource.data.regionId ||
                    isAdmin()
                  );
      // Only Regional Governors and Admins can create or update clubs.
      allow write: if isSignedIn() && (isRegionGovernor(resource.data.regionId) || isAdmin());
    }

    match /transactions/{transactionId} {
      // Users can read their own transactions.
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      // Only Admins can list all transactions.
      allow list: if isAdmin();
      // No client-side writes. All transactions must be created by the backend.
      allow write: if false;
    }

    match /governance/{ruleId} {
        // All clients can read the governance rules.
        allow read: if true;
        // Nobody can write to governance rules from the client.
        allow write: if false;
    }
    
    // Re-apply rules for existing collections that need to be accessible
    match /documents/{documentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uploadedByUserId == request.auth.uid;
    }
    
    match /events/{eventId} {
        allow read: if true;
        allow write: if hasRole('Secretary') || hasRole('President') || isAdmin();
    }

    match /partnerships/{partnershipId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /endorsements/{endorsementId} {
        allow read, write: if isAdmin();
    }
    
    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);
        allow update, delete: if false;
      }
    }
  }
}
