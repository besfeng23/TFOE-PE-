
/**
 * Core Philosophy: This ruleset establishes a hybrid security model. It combines a strict
 * user-ownership model for private data with a role-based access control (RBAC) system for
 * administrative actions.
 *
 * Data Structure: Private user data (Tasks, Notifications) is stored in subcollections under the
 * user's profile document. User profiles are in a top-level collection.
 *
 * Key Security Decisions:
 * - User Profile Management: Normal users can only read and update their OWN profile. Administrators
 *   can create, read, update, and delete ANY user profile, but cannot change their own role.
 * - Private Subcollections: By placing tasks and notifications in subcollections, we can create
 *   rules that allow users to safely list their own data without any risk of exposing others' data.
 * - Public Read-Only Collections: Collections like 'roles', and 'categories' are treated as
 *   public lookup data, readable by any signed-in user but not writable by clients.
 * - Admin-Only Writable Collections: The 'events' and 'partnerships' collections are publicly readable, but only admins can write to them.
 * - Owner-Only Writes for Public Content: The 'documents' collection is publicly readable, but write
 *   operations (create, update, delete) are restricted to the original author.
 * - Admin Role Check: The `isAdmin()` function checks a custom claim on the user's auth token.
 *   This is a performant way to verify admin status. In this ruleset, we fallback to checking
 *   the role in the user's profile document, which is less performant but works for this demo.
 *
 * Denormalization for Authorization: To ensure fast and secure rule evaluation, authorization fields are
 * denormalized directly onto the documents (e.g., 'documents' contain 'uploadedByUserId').
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Checks if the requesting user is an administrator.
     * In a production app, this would ideally check a custom claim on the auth token.
     * Here, we fall back to reading the user's profile document.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId == 'Admin';
    }
    
    /**
     * Checks if the requesting user is a Leader or an Admin.
     */
    function isLeaderOrAdmin() {
        let userRole = get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId;
        return isSignedIn() && (userRole == 'Admin' || userRole == 'Leader');
    }

    /**
     * Returns true if the document exists and the user is the owner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * Validates that the user profile being created has an 'id' field matching the document's UID.
     */
    function hasValidUserProfileIdOnCreate(userProfileId) {
      return request.resource.data.id == userProfileId;
    }

    /**
     * Enforces immutability of the user profile's 'id' field during an update.
     */
    function hasImmutableUserProfileId() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * Validates that the document being created has an 'uploadedByUserId' matching the creator.
     */
    function hasValidCreatorIdOnCreate() {
      return request.resource.data.uploadedByUserId == request.auth.uid;
    }

    /**
     * Enforces immutability of the document's 'uploadedByUserId' field.
     */
    function hasImmutableCreatorId() {
      return request.resource.data.uploadedByUserId == resource.data.uploadedByUserId;
    }

    /**
     * Validates that the resource being created has a 'userId' matching the creator.
     */
    function hasValidOwnerIdOnCreate() {
      return request.resource.data.userId == request.auth.uid;
    }

    /**
     * Enforces immutability of a resource's 'userId' field during an update.
     */
    function hasImmutableOwnerId() {
      return request.resource.data.userId == resource.data.userId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Users can read their own profile. Admins and Leaders can list all profiles.
     * @path /userProfiles/{userProfileId}
     * @allow (get) Any signed-in user can read any profile.
     * @allow (list) Any signed-in user can list profiles for the directory.
     * @allow (create) An admin can create a new user profile.
     * @allow (update) A user can update their own profile, or an admin can update any profile.
     * @allow (delete) An admin can delete any user profile.
     */
    match /userProfiles/{userProfileId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isOwner(userProfileId) || isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Users can manage their own tasks within their profile.
       * @path /userProfiles/{userProfileId}/tasks/{taskId}
       * @principle Secures a user-owned subcollection, allowing safe list and get operations.
       */
      match /tasks/{taskId} {
        allow read, write: if isOwner(userProfileId);
      }

      /**
       * @description Users can manage their own notifications within their profile.
       * @path /userProfiles/{userProfileId}/notifications/{notificationId}
       * @principle Secures a user-owned subcollection for private data.
       */
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userProfileId);
      }
    }

    /**
     * @description Roles are public, read-only data for all signed-in users.
     * @path /roles/{roleId}
     * @principle Secures lookup data by making it read-only for clients.
     */
    match /roles/{roleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if false;
    }

    /**
     * @description Documents are public to read, but only the original uploader can modify or delete them.
     * @path /documents/{documentId}
     * @principle Implements "Public Read with Owner-Only Writes" pattern.
     */
    match /documents/{documentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && hasValidCreatorIdOnCreate();
      allow update: if isExistingOwner(resource.data.uploadedByUserId) && hasImmutableCreatorId();
      allow delete: if isExistingOwner(resource.data.uploadedByUserId);
    }

    /**
     * @description Categories are public, read-only data for all signed-in users.
     * @path /categories/{categoryId}
     * @principle Secures lookup data by making it read-only for clients.
     */
    match /categories/{categoryId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if false;
    }

    /**
     * @description Events are public to read, but only admins can create, update or delete them.
     * @path /events/{eventId}
     * @principle Secures public data by making it admin-only for writes.
     */
    match /events/{eventId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    /**
     * @description Partnerships are public to read, but only admins can manage them.
     * @path /partnerships/{partnershipId}
     * @principle Secures public data by making it admin-only for writes.
     */
    match /partnerships/{partnershipId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    /**
     * @description Endorsement letters are admin-only.
     * @path /endorsements/{endorsementId}
     * @principle Restricts access to sensitive generated documents.
     */
    match /endorsements/{endorsementId} {
        allow read, write: if isAdmin();
    }


    /**
     * @description Users can manage their own attendance records. Admins can list all for analytics.
     * @path /attendance/{attendanceId}
     * @principle Enforces document ownership for writes and reads. Listing is restricted to admins.
     */
    match /attendance/{attendanceId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isLeaderOrAdmin(); // Allow admin and leaders to list for analytics
      allow create: if isSignedIn() && hasValidOwnerIdOnCreate();
      allow update: if isExistingOwner(resource.data.userId) && hasImmutableOwnerId();
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Users can only access their own payment receipts. Listing is denied for privacy.
     * @path /receipts/{receiptId}
     * @principle Enforces document ownership for reads and writes. Listing is denied to prevent data leakage.
     */
    match /receipts/{receiptId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if false; // Denied to prevent leaking all users' receipt data.
      allow create: if isSignedIn() && hasValidOwnerIdOnCreate();
      allow update: if isExistingOwner(resource.data.userId) && hasImmutableOwnerId();
      allow delete: if isExistingOwner(resource.data.userId);
    }
    
    /**
     * @description AI-generated summaries are public, read-only data for all signed-in users.
     * @path /automatedSummaries/{automatedSummaryId}
     * @principle Secures machine-generated data by making it read-only for clients.
     */
    match /automatedSummaries/{automatedSummaryId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if false;
    }

    /**
     * @description Rules for real-time messaging.
     * @path /conversations/{conversationId}
     * @principle Participants can read/write to conversations they are part of.
     */
    match /conversations/{conversationId} {
      // A user can read a conversation document (get) or a list of conversation
      // documents (list) if their UID is in the `participants` array.
      // For a 'list' query, the client MUST use a `where('participants', 'array-contains', request.auth.uid)`
      // filter to ensure they only request documents they are allowed to see.
      allow read: if request.auth.uid in resource.data.participants;
      
      // A user can create a conversation if their UID is in the participants list of the new document.
      allow create: if request.auth.uid in request.resource.data.participants;
      
      // A user can update or delete a conversation (e.g., the lastMessage field) if they are a participant.
      allow update, delete: if request.auth.uid in resource.data.participants;
      
      /**
       * @description Rules for messages within a conversation.
       * @path /conversations/{conversationId}/messages/{messageId}
       * @principle Inherits parent rule; only conversation participants can read/write messages.
       */
      match /messages/{messageId} {
        // A user can read messages if they are part of the parent conversation.
        // This rule uses `get()` to check the parent document's `participants` array.
        allow read: if get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);

        // A user can create a message if they are part of the conversation and are the sender.
        allow create: if get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
                       && request.resource.data.senderId == request.auth.uid;

        // No one can update or delete a message.
        allow update, delete: if false;
      }
    }
  }
}
