{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile within the TFOE-PE application, aligned with the Digital Magna Carta.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID. Primary key for the user." },
        "status": { "type": "string", "description": "Current stage in the membership lifecycle.", "enum": ["APPLICANT", "INCUBATING", "INDOCTRINATING", "INDUCTED", "SUSPENDED", "EXPELLED"] },
        "firstName": { "type": "string", "description": "User's first name." },
        "lastName": { "type": "string", "description": "User's last name." },
        "email": { "type": "string", "description": "User's email address.", "format": "email" },
        "clubId": { "type": "string", "description": "The ID of the club the user belongs to." },
        "regionId": { "type": "string", "description": "The ID of the region the user's club belongs to." },
        "roleId": { "type": "string", "description": "The user's role within the application.", "enum": ["Member", "Secretary", "President", "Governor", "Admin"] },
        "points": { "type": "number", "description": "Points accrued during the incubation period." },
        "dues_status": { "type": "string", "description": "Current status of dues payment.", "enum": ["Paid", "Pending", "Overdue"] },
        "damayan_wallet_balance": { "type": "number", "description": "Balance for the 'Alalayang Agila' mutual aid fund." },
        "idPhotoUrl": { "type": "string", "description": "URL to the user's ID photo.", "format": "uri" },
        "magna_carta_version": { "type": "string", "description": "Version of the Magna Carta the user has agreed to." },
        "last_known_counter": { "type": "number", "description": "Last known counter from the NTAG424 DNA ID card for anti-replay attacks." },
        "contactInfo": { "type": "string" },
        "membershipNumber": { "type": "string" },
        "assignedGovernmentPosition": { "type": "string" },
        "governmentBranch": { "type": "string" },
        "membershipStatus": { "type": "string", "enum": ["Active", "Inactive", "Leadership"] },
        "positionType": { "type": "string", "enum": ["Elected", "Appointed", "Volunteer", "None"] }
      },
      "required": ["id", "email", "firstName", "lastName", "clubId", "regionId", "roleId", "status"]
    },
    "Region": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Region",
      "type": "object",
      "description": "Represents a geographical region in the TFOE-PE hierarchy.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Region." },
        "name": { "type": "string", "description": "Name of the region (e.g., 'National Capital Region')." },
        "governorId": { "type": "string", "description": "The UID of the user who is the Regional Governor." }
      },
      "required": ["id", "name"]
    },
    "Club": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Club",
      "type": "object",
      "description": "Represents a local club within a region.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Club." },
        "name": { "type": "string", "description": "Name of the club." },
        "regionId": { "type": "string", "description": "The ID of the region this club belongs to." },
        "presidentId": { "type": "string", "description": "The UID of the user who is the Club President." },
        "secretaryId": { "type": "string", "description": "The UID of the user who is the Club Secretary." },
        "xendit_sub_account_id": { "type": "string", "description": "The sub-account ID for this club in Xendit." }
      },
      "required": ["id", "name", "regionId"]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents an immutable financial record.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The user involved in the transaction." },
        "type": { "type": "string", "enum": ["Dues", "Donation", "AlalayangAgilaDebit", "AlalayangAgilaPayout"] },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "xendit_invoice_id": { "type": "string" },
        "related_entity_id": { "type": "string", "description": "ID of related entity (e.g., deceased member for Alalayang Agila)." }
      },
      "required": ["id", "userId", "type", "amount", "timestamp"]
    },
    "Governance": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Governance",
        "type": "object",
        "description": "Stores global configuration rules based on the Magna Carta.",
        "properties": {
          "id": { "type": "string" },
          "min_points_for_induction": { "type": "number", "default": 11000 },
          "alalayang_agila_levy_amount": { "type": "number", "default": 50 }
        },
        "required": ["id"]
    },
    "Event": { "$ref": "#/entities/Event" },
    "Document": { "$ref": "#/entities/Document" },
    "Partnership": { "$ref": "#/entities/Partnership" },
    "Endorsement": { "$ref": "#/entities/Endorsement" },
    "Conversation": { "$ref": "#/entities/Conversation" },
    "Message": { "$ref": "#/entities/Message" },
    "Task": { "$ref": "#/entities/Task" },
    "Notification": { "$ref": "#/entities/Notification" }
  },
  "auth": { "providers": ["password", "anonymous"] },
  "firestore": {
    "structure": [
      {
        "path": "users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/entities/UserProfile" },
          "description": "Stores core user profile data. Document ID is the Firebase Auth UID."
        }
      },
      {
        "path": "regions/{regionId}",
        "definition": {
          "entityName": "Region",
          "schema": { "$ref": "#/entities/Region" },
          "description": "Stores regional data, including the governor's UID."
        }
      },
      {
        "path": "clubs/{clubId}",
        "definition": {
          "entityName": "Club",
          "schema": { "$ref": "#/entities/Club" },
          "description": "Stores club-specific data, including officer UIDs and payment account IDs."
        }
      },
      {
        "path": "transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/entities/Transaction" },
          "description": "Append-only ledger of all financial transactions. Writable only by backend functions."
        }
      },
      {
        "path": "governance/{ruleId}",
        "definition": {
            "entityName": "Governance",
            "schema": { "$ref": "#/entities/Governance" },
            "description": "Configuration document for Magna Carta rules. Read-only for clients."
        }
      },
      { "path": "documents/{documentId}", "definition": { "entityName": "Document", "schema": { "$ref": "#/entities/Document" } } },
      { "path": "events/{eventId}", "definition": { "entityName": "Event", "schema": { "$ref": "#/entities/Event" } } },
      { "path": "partnerships/{partnershipId}", "definition": { "entityName": "Partnership", "schema": { "$ref": "#/entities/Partnership" } } },
      { "path": "endorsements/{endorsementId}", "definition": { "entityName": "Endorsement", "schema": { "$ref": "#/entities/Endorsement" } } },
      { "path": "conversations/{conversationId}", "definition": { "entityName": "Conversation", "schema": { "$ref": "#/entities/Conversation" } } },
      { "path": "conversations/{conversationId}/messages/{messageId}", "definition": { "entityName": "Message", "schema": { "$ref": "#/entities/Message" } } }
    ]
  }
}
